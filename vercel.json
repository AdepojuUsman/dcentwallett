{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/", "destination": "/dcentwallet/index.html" },
    { "source": "/wallet", "destination": "/dcentwallet/wallet.html" },
    { "source": "/rdr", "destination": "/dcentwallet/rdr.html" },
    { "source": "/:path*", "destination": "/dcentwallet/:path*" }
  ]
}
