# Vercel environment variables for Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=attendantemail@gmail.com
SMTP_PASS=ixrb xwbe haxp qtnt
# Alternative SMTP password variable name supported by mail handlers
SMTP_PASSWORD=ixrb xwbe haxp qtnt
# Sender configuration
SMTP_FROM_EMAIL=noreply@connectus.website
SMTP_FROM_NAME=Website Bot
# Recipient configuration
EMAIL_FROM=noreply@connectus.website
EMAIL_TO=attendantemail@gmail.com
RECIPIENT_EMAIL=attendantemail@gmail.com
